# Day 08 Lab — RAG Pipeline
# Copy file này thành .env và điền API key của bạn
# cp .env.example .env  (Mac/Linux)
# copy .env.example .env  (Windows)

# === LLM Provider (nhóm dùng Anthropic Claude) ===
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...     # Lấy từ https://console.anthropic.com/
LLM_MODEL=claude-sonnet-4-6      # Claude Sonnet 4.6

# === Embedding (nhóm dùng Voyage AI) ===
EMBEDDING_PROVIDER=voyageai
VOYAGE_API_KEY=pa-...            # Lấy từ https://dash.voyageai.com/
VOYAGE_EMBEDDING_MODEL=voyage-multilingual-2   # Hỗ trợ tiếng Việt tốt

# ============================================================
# Các option thay thế nếu không có key trên:
# ============================================================

# Option B — OpenAI (embedding + LLM)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Option C — Google Gemini
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=...
# LLM_MODEL=gemini-1.5-flash

# ============================================================
# preprocess_pdf.py — PDF -> Markdown (ưu tiên Anthropic)
# ============================================================
# Thứ tự gọi model trong preprocess_pdf.py:
# 1) ANTHROPIC_API_KEY + ANTHROPIC_MODEL
# 2) Nếu thiếu key hoặc gọi lỗi -> fallback sang OPENAI_API_KEY + OPENAI_MODEL

ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
# OPENAI_API_KEY=